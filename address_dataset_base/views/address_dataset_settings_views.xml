<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_address_dataset_settings_form" model="ir.ui.view">
        <field name="name">address.dataset.settings.form</field>
        <field name="model">address.dataset.settings</field>
        <field name="arch" type="xml">
            <form string="Address Dataset Configuration" create="0" delete="0">
                <sheet>
                    <group>
                        <field name="name" invisible="1"/>
                        <field name="hide_coordinates"/>
                    </group>
                </sheet>
                <footer>
                    <button name="action_save" type="object" string="Save" class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
